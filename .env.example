# -----------------------------
# Runtime
# -----------------------------
APP_ENV=local
APP_DEBUG=true
TIMEZONE=Asia/Shanghai

# -----------------------------
# API
# -----------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=xhsocr
POSTGRES_USER=xhsocr
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://xhsocr:change_me@127.0.0.1:5432/xhsocr

# -----------------------------
# Queue (Redis)
# -----------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------
# Storage (Local FS for MVP)
# -----------------------------
STORAGE_PROVIDER=local
STORAGE_ROOT=./storage
UPLOAD_ROOT=./storage/uploads
BOOK_ROOT=./storage/books
TASK_ROOT=./storage/tasks

# -----------------------------
# OCR
# -----------------------------
OCR_PROVIDER=rapidocr_onnxruntime
OCR_LANG=ch
OCR_TIMEOUT_SECONDS=90
OCR_ISOLATE_SUBPROCESS=true
OCR_ALLOW_UNSTABLE_RUNTIME=false
OCR_AUTO_DOWNGRADE_MACOS=true

# -----------------------------
# LLM (OpenRouter)
# -----------------------------
LLM_PROVIDER=mock
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace_with_real_key
OPENROUTER_MODEL=openai/gpt-5-mini
LLM_TIMEOUT_SECONDS=300
LLM_RETRY_COUNT=1
LLM_RETRY_BACKOFF_SECONDS=1

# -----------------------------
# Concurrency Target
# -----------------------------
WORKER_CONCURRENCY=20
OCR_MAX_PARALLEL=6
LLM_MAX_PARALLEL=20

# -----------------------------
# Security
# -----------------------------
# Never commit real secrets.
